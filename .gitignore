# Dependencies
**/node_modules
.pnpm-store/

# Build outputs
dist/
build/
*.dist

# User uploads (保留目录结构)
uploads/news/*
!uploads/news/.gitkeep

# 资讯导入：本机保存的站点登录态（含 Cookie，勿提交）
data/import-sessions/*.json

# Environment variables（勿提交；git pull/merge 不会覆盖本机 .env）
# 勿执行 git add -f .env；慎用 git clean -fdx 会删除被忽略的 .env
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock
*.bak

# Coverage directory used by tools like istanbul
coverage/
*.lcov

# nyc test coverage
.nyc_output

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next

# Nuxt.js build / generate output
.nuxt

# Gatsby files
.cache/

# Storybook build outputs
.out
.storybook-out

# Temporary folders
tmp/
temp/

# Database
*.db
*.sqlite
*.sqlite3

# Webdev artifacts (checkpoint zips, migrations, etc.)
.webdev/

# Manus version file (auto-generated, not part of source)
client/public/__manus__/version.json

# pdf.js worker：由 vite 插件从 pdfjs-dist 拷入，勿提交大文件
client/public/pdf.worker.min.mjs
